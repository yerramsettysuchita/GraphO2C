**/__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Virtual environments
.venv/
venv/
env/
ENV/

# React build output (built by Render at deploy time)
frontend-dist/

# Node
frontend/node_modules/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp

# Logs
*.log

# Coverage
backend/coverage.xml
backend/.coverage
