# Copy this file to .env and fill in your values.
# Never commit .env — it is gitignored.

# Required: Groq API key (https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Optional: API key to protect the /query endpoint.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# If not set, /query is publicly accessible (fine for local dev).
GRAPHO2C_API_KEY=your_grapho2c_api_key_here

# Optional: Sentry DSN for error tracking and APM.
# Free tier: 5,000 errors/month. Get DSN at sentry.io → New Project → Python.
# When not set, Sentry is silently disabled — no errors raised.
SENTRY_DSN=

# Environment tag shown in Sentry and /metrics.
ENVIRONMENT=development

# Set automatically by Render — add manually if self-hosting
# RENDER_EXTERNAL_URL=https://grapho2c.onrender.com
